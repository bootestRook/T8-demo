{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "skills": {
    "paths": [
      ".agents/skills"
    ]
  },
  "permission": "allow",
  "mcp": {
    "godot": {
      "type": "local",
      "command": [
        "cmd",
        "/c",
        "scripts/godot_mcp_stdio.cmd"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}
