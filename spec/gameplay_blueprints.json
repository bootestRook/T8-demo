{
  "schema_version": "v1",
  "experience_floor": {
    "default": {
      "min_content_units": 3,
      "requires_unit_differences": true,
      "requires_stage_change": true,
      "requires_settlement": true,
      "requires_progress": true,
      "requires_decision_pressure": true
    },
    "starter_template": {
      "skip_small_complete_review": true
    },
    "dynamic_keywords": ["动作", "射击", "生存", "敌人", "怪物", "平台", "跳跃", "跑酷", "搜打撤", "撤离", "塔防", "弹幕", "ARPG", "战斗"],
    "dynamic_blueprints": ["roguelite", "extraction", "tower_defense", "loot_arpg", "parkour", "level_design"],
    "genre_requirements": {
      "extraction": ["搜集", "撤离", "死亡损失", "高价值", "风险"],
      "tower_defense": ["路线", "波次", "基地", "敌人"],
      "loot_arpg": ["战斗", "掉落", "装备", "成长"],
      "parkour": ["障碍", "距离", "失败", "节奏"],
      "inventory_backpack": ["物品", "格子", "容量", "组合"]
    }
  },
  "default_blueprints": ["common_loop"],
  "blueprints": [
    {
      "id": "common_loop",
      "name": "通用可玩闭环",
      "aliases": ["通用闭环", "核心闭环", "基础闭环"],
      "concept_required": ["概念ID", "一句话目标", "玩法不变量", "禁止污染项", "验收标准"],
      "code_checks": [
        {
          "name": "开始入口",
          "files": ["src/game/PrototypeState.gd", "scenes/Game.gd"],
          "any": ["start_round", "_start", "_on_main_menu_start_requested", "start_battle_ui"]
        },
        {
          "name": "成功条件",
          "files": ["src/game/PrototypeState.gd", "scenes/Game.gd"],
          "any": ["Phase.SUCCESS", "_end_round(Phase.SUCCESS", "Phase.WON"]
        },
        {
          "name": "失败条件",
          "files": ["src/game/PrototypeState.gd", "scenes/Game.gd"],
          "any": ["Phase.FAILURE", "fail(", "Phase.LOST"]
        },
        {
          "name": "重开路径",
          "files": ["scenes/Game.gd", "src/ui/Hud.gd"],
          "any": ["_restart", "request_round_restart", "再来", "重开", "PrototypeState.reset", "result_retry_button"]
        },
        {
          "name": "输入覆盖",
          "files": ["scenes/Game.gd", "src/ui/Hud.gd", "src/game/Player.gd"],
          "any": ["KEY_LEFT", "KEY_RIGHT", "ui_left", "ui_right", "try_play_hand_card", "_request_card_play"],
          "also_any": ["KEY_A", "KEY_D", "KEY_W", "KEY_S", "InputEventMouseButton", "_on_card_gui_input"]
        }
      ]
    },
    {
      "id": "starter_template",
